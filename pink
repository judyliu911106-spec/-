<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>夢幻粉紅記帳</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
</head>
<body>
    <div class="app-shell">
        <div class="glass-panel text-center">
            <div class="bubble-decor">🌸</div>
            <h2 class="panel-title">本月累積花費</h2>
            <div class="total-amount">NT$ <span id="month-total">0</span></div>
        </div>

        <div class="glass-panel">
            <h3 class="panel-sub-title">💰 預算餘額分配</h3>
            <div class="budget-grid">
                <div class="budget-item"><span>存錢:</span><input type="number" id="bg-save" onchange="updateBudget('save', this.value)"></div>
                <div class="budget-item"><span>可花費:</span><input type="number" id="bg-spend" onchange="updateBudget('spend', this.value)"></div>
                <div class="budget-item"><span>美妝:</span><input type="number" id="bg-makeup" onchange="updateBudget('makeup', this.value)"></div>
                <div class="budget-item"><span>運動:</span><input type="number" id="bg-sport" onchange="updateBudget('sport', this.value)"></div>
                <div class="budget-item"><span>保險:</span><input type="number" id="bg-insurance" onchange="updateBudget('insurance', this.value)"></div>
            </div>
        </div>

        <div class="glass-panel keep-panel">
            <div class="input-row">
                <input type="date" id="tx-date">
                <input type="text" id="tx-item" placeholder="項目內容 (選填)">
            </div>
            
            <div class="category-container">
                <div class="cat-btn" onclick="selectCat('主食')">🍱 主食</div>
                <div class="cat-btn" onclick="selectCat('點心')">🍰 點心</div>
                <div class="cat-btn" onclick="selectCat('住宿')">🎀 住宿</div>
                <div class="cat-btn" onclick="selectCat('交通')">🚗 交通</div>
                <div class="cat-btn" onclick="selectCat('購物')">🛍️ 購物</div>
                <div class="cat-btn" onclick="selectCat('治裝')">👗 治裝</div>
                <div class="cat-btn" onclick="selectCat('電話及會員')">📱 電話會員</div>
                <div class="cat-btn" onclick="selectCat('醫療')">🏥 醫療</div>
                <div class="cat-btn" onclick="selectCat('保養美體')">💅 保養美體</div>
                <div class="cat-btn" onclick="selectCat('儲值及娛樂')">🎮 娛樂儲值</div>
                <div class="cat-btn" onclick="selectCat('狗勾')">🐶 狗勾</div>
                <div class="cat-btn" onclick="selectCat('其他')">✨ 其他</div>
            </div>

            <div class="amount-display">已選分類: <span id="selected-cat-text" style="color:#ff69b4;">未選擇</span> | 金額: $<span id="tx-amount">0</span></div>
            
            <div class="keyboard">
                <div class="key" onclick="pressKey('1')">1</div><div class="key" onclick="pressKey('2')">2</div><div class="key" onclick="pressKey('3')">3</div>
                <div class="key" onclick="pressKey('4')">4</div><div class="key" onclick="pressKey('5')">5</div><div class="key" onclick="pressKey('6')">6</div>
                <div class="key" onclick="pressKey('7')">7</div><div class="key" onclick="pressKey('8')">8</div><div class="key" onclick="pressKey('9')">9</div>
                <div class="key backspace" onclick="pressKey('C')">⌫</div><div class="key" onclick="pressKey('0')">0</div>
                <div class="key submit-btn" onclick="submitRecord()">送出🌸</div>
            </div>
        </div>
        
        <div class="nav-bar">
            <a href="index.html" class="nav-item active">記帳首頁</a>
            <a href="details.html" class="nav-item">明細歷史</a>
        </div>
    </div>

    <script>
        // ⚠️ 貼上你剛才從 Google 得到的網頁應用程式 URL
        const GAS_URL = "https://script.google.com/macros/s/AKfycbysT5brkEOmCNvDw_LWeesJlDLr-W_jH9DzK2itaa_6oeMdq27w0_rHvUfD_t0QTyW8/exec"; 

        let currentAmount = "0";
        let chosenCategory = "";

        // 初始化設定
        window.addEventListener('load', () => {
            document.getElementById('tx-date').valueAsDate = new Date();
            // 先載入 LocalStorage 讓畫面秒出數字
            const fields = ['save', 'spend', 'makeup', 'sport', 'insurance'];
            fields.forEach(f => {
                if(localStorage.getItem('budget_'+f)) document.getElementById('bg-'+f).value = localStorage.getItem('budget_'+f);
            });
            // 從雲端同步最新累積總額與預算
            fetch(`${GAS_URL}?action=getData`)
                .then(res => res.json())
                .then(data => {
                    // 計算當月累積金額
                    let total = data.records.reduce((sum, r) => sum + r.amount, 0);
                    document.getElementById('month-total').innerText = total.toLocaleString();
                    
                    // 同步雲端預算到輸入框與快取
                    fields.forEach(f => {
                        if(data.budgets[f]) {
                            document.getElementById('bg-'+f).value = data.budgets[f];
                            localStorage.setItem('budget_'+f, data.budgets[f]);
                        }
                    });
                });
        });

        function selectCat(cat) {
            chosenCategory = cat;
            document.getElementById('selected-cat-text').innerText = cat;
        }

        function pressKey(key) {
            if (key === 'C') {
                currentAmount = currentAmount.length > 1 ? currentAmount.slice(0, -1) : "0";
            } else {
                currentAmount = currentAmount === "0" ? key : currentAmount + key;
            }
            document.getElementById('tx-amount').innerText = currentAmount;
        }

        // 修改預算自動存本機與雲端
        function updateBudget(cat, val) {
            localStorage.setItem('budget_' + cat, val);
            fetch(`${GAS_URL}?action=updateBudget&category=${cat}&amount=${val}`);
        }

        // 送出記帳明細到 Google
        function submitRecord() {
            if (!chosenCategory) { alert("請先選擇一個可愛的分類唷！"); return; }
            if (currentAmount === "0") { alert("請輸入金額！"); return; }

            const payload = {
                date: document.getElementById('tx-date').value,
                category: chosenCategory,
                item: document.getElementById('tx-item').value,
                amount: currentAmount
            };

            fetch(GAS_URL, {
                method: "POST",
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(res => {
                alert(res.message);
                location.reload(); // 重新整理更新當月總額
            });
        }
    </script>
</body>
</html>
